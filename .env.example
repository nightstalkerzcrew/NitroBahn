# ── NFSW Portal configuration ───────────────────────────────────────────────
# Copy this file to ".env" and adjust. Everything has a sane default for local
# testing, so the server runs out of the box even without a .env file.

# HTTP port the portal listens on
PORT=8080

# Secret used to sign login session tokens (JWT). CHANGE THIS in production.
JWT_SECRET=change-me-to-a-long-random-string

# Database backend: "sqlite" (default, zero-setup, great for testing) or
# "mysql" (connect to a real Soapbox Race World / SBRW game database).
DB_DRIVER=sqlite

# Path to the SQLite file (only used when DB_DRIVER=sqlite)
SQLITE_PATH=./data/portal.db

# ── MySQL / SBRW connection (only used when DB_DRIVER=mysql) ─────────────────
# Point these at the same MySQL database your soapbox-race-core server uses,
# and the leaderboard + login read live game data. See README "Going live".
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=soapbox
MYSQL_PASSWORD=secret
MYSQL_DATABASE=soapbox
